# SecondMe OAuth2 配置
SECONDME_CLIENT_ID=your_client_id_here
SECONDME_CLIENT_SECRET=your_client_secret_here
SECONDME_REDIRECT_URI=http://localhost:3000/api/auth/callback

# 数据库
DATABASE_URL="file:./dev.db"

# SecondMe API
SECONDME_API_BASE_URL=https://api.mindverse.com/gate/lab
SECONDME_OAUTH_URL=https://second-me.cn/oauth
SECONDME_TOKEN_ENDPOINT=https://api.mindverse.com/gate/lab/api/oauth/token/code
SECONDME_REFRESH_ENDPOINT=https://api.mindverse.com/gate/lab/api/oauth/token/refresh
SECONDME_USER_PROFILE_ENDPOINT=https://api.mindverse.com/gate/lab/api/secondme/user/info

# Kimi API 配置
KIMI_API_ENDPOINT=https://api.kimi.com/coding/v1/messages
KIMI_API_KEY=your_kimi_api_key_here

# 应用配置
NEXT_PUBLIC_APP_NAME="人间观察站"
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 知乎 OpenAPI 配置
ZHIHU_APP_KEY=your_zhihu_app_key
ZHIHU_APP_SECRET=your_zhihu_app_secret
