# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (包含敏感信息，不要上传)
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# SecondMe config (contains sensitive data)
.secondme/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Prisma
prisma/*.db
prisma/*.db-journal
prisma/migrations/*/migration_lock.toml

# Logs
*.log
logs/

# Local development
.claude/

# OS files
*.tmp
*.temp
.cache/

# 压缩包
*.tar.gz
*.zip
*.rar
*.7z

# 上传的文件
uploads/
public/uploads/

# 备份文件
*.bak
*.backup
